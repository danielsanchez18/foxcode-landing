---
import Logo from "@/assets/logos/logo.webp";
---

<div class="bg-lianear-to-b from-black/90 via-black/30 to-background/10 -mt-15 pt-25 pb-0 relative">

    <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-b from-black/90 via-black/30 to-background/10 -z-20"></div>

    <!-- <div class="absolute flex items-end justify-center top-0 left-0 w-full h-full -z-10">
        <div class="bg-white/10 w-full h-96 blur-2xl animate-pulse"></div>
    </div> -->

    <section
        class="w-full max-w-2xl mx-auto flex flex-col gap-5 md:min-h-135 py-20 max-xl:px-5"
    >
        <div class="flex flex-col space-y-4 text-center max-w-3xl m-auto ">
            <div class="flex items-center justify-center gap-x-2">
                <img
                    src={Logo.src}
                    alt="FoxCode Logo"
                    class="w-6 h-6 logo-icon"
                />
                <h1 class="text-lg font-medium text-white">FoxCode</h1>
            </div>
            <h2 class="text-4xl sm:text-5xl lg:text-6xl text-balance font-semibold">
                Transformando ideas en <span class="text-primary">realidad</span
                >
            </h2>
            <p class="text-neutral-300 mx-auto mt-2">
                Te acompañamos desde la validación y el diseño hasta el
                desarrollo y la puesta en marcha, para que tu software escale al
                ritmo de tu negocio.
            </p>
            <!-- Buttons -->
            <div class="flex items-center gap-x-3 mt-5 w-fit mx-auto">
                <button
                    type="button"
                    class="bg-primary text-white font-medium px-4 py-2.5 rounded-full hover:bg-primary-dark transition cursor-pointer"
                    aria-haspopup="dialog" 
                    aria-expanded="false" 
                    aria-controls="contact-us-modal" 
                    aria-label="Toggle navigation" 
                    data-hs-overlay="#contact-us-modal"
                >
                    Compártenos tu idea
                </button>
                <a href="/servicios">
                    <button
                        type="button"
                        class="hidden sm:block bg-white/5 text-white font-medium px-4 py-2.5 rounded-full hover:bg-white/10 transition cursor-pointer"
                    >
                        Descubre nuestros servicios
                    </button>
                </a>
            </div>
        </div>
    </section>
</div>

<style>
    .logo-icon {
        filter: invert(1) brightness(1.2);
    }
</style>
