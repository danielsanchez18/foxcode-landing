---
import User1 from '@/assets/images/users/user1.webp';
import User2 from '@/assets/images/users/user2.webp';
import User3 from '@/assets/images/users/user3.webp';
---

<!-- Metric Grid -->
  <div
    class="max-w-5xl mx-auto flex max-sm:flex-col items-center justify-center w-full rounded-xl border border-white/10 bg-linear-to-t from-black/40 to-transparent"
  >
    <!-- Metric 1 -->
    <div
      class="w-full py-7 flex flex-col items-center justify-center relative first:before:hidden before:absolute before:-top-full sm:before:top-1/2 before:start-1/2 sm:before:start-0 before:w-px before:h-20 before:bg-neutral-600 before:rotate-60 sm:before:rotate-12 before:transform sm:before:-translate-y-1/2 before:-translate-x-1/2 sm:before:translate-x-0 before:mt-3.5 sm:before:mt-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="size-12 text-primary mb-5">
      <g clip-path="url(#clip0_4418_9716)">
        <path d="M12.37 8.88086H17.62" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M6.38 8.88086L7.13 9.63086L9.38 7.38086" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M12.37 15.8809H17.62" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M6.38 15.8809L7.13 16.6309L9.38 14.3809" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M9 22H15C20 22 22 20 22 15V9C22 4 20 2 15 2H9C4 2 2 4 2 9V15C2 20 4 22 9 22Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
      </g>
      <defs>
        <clipPath id="clip0_4418_9716">
          <rect width="24" height="24" fill="white"/>
        </clipPath>
      </defs>
      </svg>
      <p class="text-white text-3xl font-semibold">15+</p>
      <p class="text-white/60">Proyectos lanzados</p>
    </div>

    <!-- Metric 2 -->
    <div
      class="w-full py-14 sm:py-7 flex flex-col items-center justify-center relative first:before:hidden before:absolute before:-top-10 sm:before:top-1/2 before:start-1/2 sm:before:start-0 before:w-px before:h-20 before:bg-neutral-600 before:rotate-75 sm:before:rotate-12 before:transform sm:before:-translate-y-1/2 before:-translate-x-1/2 sm:before:translate-x-0 before:mt-3.5 sm:before:mt-0"
    >
      <div class="relative mb-5 h-14 w-14">
        <div
          class="size-9 rounded-full border-2 border-white/10 bg-neutral-900 absolute top-0 left-8 -translate-x-1/2 z-10 overflow-hidden"
        >
          <img src={User3.src} alt="User 3" class="object-cover w-full">
        </div>
        <div
          class="size-9 rounded-full border-2 border-white/10 bg-neutral-900 absolute bottom-0 left-0 z-20 overflow-hidden"
        >
          <img src={User1.src} alt="User 1" class="object-cover h-full">
        </div>
        <div
          class="size-9 rounded-full border-2 border-white/10 bg-neutral-900 absolute bottom-0 left-7 z-0 overflow-hidden"
        >
          <img src={User2.src} alt="User 2" class="object-cover w-full">
        </div>
      </div>

      <p class="text-white text-3xl font-semibold">100%</p>
      <p class="text-white/60">Clientes satisfechos</p>
    </div>

    <!-- Metric 3 -->
    <div
      class="w-full py-7 flex flex-col items-center justify-center relative first:before:hidden before:absolute before:-top-16 sm:before:top-1/2 before:start-1/2 sm:before:start-0 before:w-px before:h-20 before:bg-neutral-600 before:rotate-75 sm:before:rotate-12 before:transform sm:before:-translate-y-1/2 before:-translate-x-1/2 sm:before:translate-x-0 before:mt-3.5 sm:before:mt-0"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" class="size-12 text-primary mb-5">
        <g clip-path="url(#clip0_4418_9919)">
          <path d="M12.0001 7.89062L10.9301 9.75063C10.6901 10.1606 10.8901 10.5006 11.3601 10.5006H12.6301C13.1101 10.5006 13.3001 10.8406 13.0601 11.2506L12.0001 13.1106" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M8.29999 18.0402V16.8802C5.99999 15.4902 4.10999 12.7802 4.10999 9.90018C4.10999 4.95018 8.65999 1.07018 13.8 2.19018C16.06 2.69018 18.04 4.19018 19.07 6.26018C21.16 10.4602 18.96 14.9202 15.73 16.8702V18.0302C15.73 18.3202 15.84 18.9902 14.77 18.9902H9.25999C8.15999 19.0002 8.29999 18.5702 8.29999 18.0402Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
          <path d="M8.5 21.9992C10.79 21.3492 13.21 21.3492 15.5 21.9992" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </g>
        <defs>
          <clipPath id="clip0_4418_9919">
            <rect width="24" height="24" fill="white"/>
          </clipPath>
        </defs>
      </svg>
      <p class="text-white text-3xl font-semibold">2+</p>
      <p class="text-white/60">Años innovando</p>
    </div>
  </div>
  <!-- End Metrics -->